{
  "name": "loan_calculator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 3005",
    "build": "next build",
    "start": "next start --port 3005",
    "lint": "next lint",
    "blog:generate": "npx tsx scripts/blog/generate-post.ts",
    "blog:generate-all": "npx tsx scripts/blog/generate-all.ts",
    "blog:list": "npx tsx -e \"import('./scripts/blog/post-list.ts').then(m => m.POSTS.forEach(p => console.log(p.slug)))\"",
    "blog:check": "npx tsx scripts/blog/check-quality.ts",
    "blog:schedule": "npx tsx scripts/blog/autonomous/scheduler.ts",
    "blog:init-queue": "npx tsx scripts/blog/autonomous/init-queue.ts",
    "blog:queue": "node -e \"try{const q=require('./data/blog-queue.json');console.log('Queue:',q.length,'posts');q.slice(0,5).forEach((p,i)=>console.log(i+1+'.',p.seoKeyword))}catch{console.log('Queue empty or not initialized')}\"",
    "blog:regen-image": "npx tsx scripts/blog/regenerate-images.ts",
    "blog:audit-images": "npx tsx scripts/blog/regenerate-images.ts --check",
    "seo:metrics": "npx tsx scripts/seo/collect-metrics.ts",
    "lighthouse": "node scripts/lighthouse-audit.mjs"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
