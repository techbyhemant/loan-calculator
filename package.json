    "@trpc/react-query": "^11.13.0",
    "@trpc/server": "^11.13.0",
    "chart.js": "^4.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.23.3",
